// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  slug         String?   @unique
  description  String?
  logoUrl      String?
  address      String?
  contactEmail String?
  contactPhone String?
  joinCode     String?  @unique // Secure code needed for COACH/PLAYER to join
  users        User[]
  teams        Team[]
  sessions     Session[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model User {
  id                   Int            @id @default(autoincrement())
  email                String         @unique
  username             String         @unique
  password             String
  role                 Role           @default(COACH)
  organizationId       Int
  organization         Organization   @relation(fields: [organizationId], references: [id])
  failedLoginAttempts  Int            @default(0)
  lockoutUntil         DateTime?
  resetPasswordToken   String?        @unique
  resetPasswordExpires DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  coachProfile         Coach?
  playerProfile        Player?
  refreshTokens        RefreshToken[]
}

model RefreshToken {
  id          Int      @id @default(autoincrement())
  hashedToken String   @unique
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
}

enum Role {
  SUPER_ADMIN
  CLUB_ADMIN
  COACH
  ANALYST
  PLAYER
}

model Coach {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  user         User     @relation(fields: [userId], references: [id])
  bio          String?
  specialty    String[] // e.g., ["Tactical", "Goalkeeping"]
  licenseLevel String[] // e.g., ["UEFA Pro", "AFC A"]
  teams        Team[]
  sessions     Session[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Player {
  id      Int      @id @default(autoincrement())
  userId  Int      @unique
  user    User     @relation(fields: [userId], references: [id])
  teamId  Int?
  team    Team?    @relation(fields: [teamId], references: [id])
  metrics Metric[]
  sessionParticipants SessionParticipant[]
  phone        String?
  address      String?
  city         String?
  country      String?
  postalCode   String?
  birthdate    DateTime?
  nationality  String?

  // Bio / physical
  position           String?
  secondaryPositions String[]
  heightCm           Int?
  weightKg           Int?
  dominantFoot       DominantFoot?
  bio                String?
  attributes         Json?

  // Metadata
  isActive          Boolean           @default(true)
  profileVisibility ProfileVisibility?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model Team {
  id             Int          @id @default(autoincrement())
  name           String
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])
  coachId        Int
  coach          Coach        @relation(fields: [coachId], references: [id])
  players        Player[]
  sessions       Session[]
}

enum DominantFoot {
  LEFT
  RIGHT
  BOTH
}

enum ProfileVisibility {
  PUBLIC
  INTERNAL
  PRIVATE
}

model Session {
  id             Int          @id @default(autoincrement())
  title          String
  date           DateTime
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])
  coachId        Int
  coach          Coach        @relation(fields: [coachId], references: [id])
  videos         Video[]
  teamId         Int?
  team           Team?        @relation(fields: [teamId], references: [id])

  type           SessionType  @default(TECHNICAL)
  duration       Int?         // duration in minutes
  intensity      Int?         // 1-10 scale
  status         SessionStatus @default(PLANNED)
  venue          String?
  notes          String?

  participants   SessionParticipant[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model SessionParticipant {
  id              Int             @id @default(autoincrement())
  sessionId       Int
  session         Session         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  playerId        Int
  player          Player          @relation(fields: [playerId], references: [id])
  role            String?
  attendanceStatus AttendanceStatus @default(PENDING)
  joinedAt        DateTime?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([sessionId, playerId])
}

model Video {
  id        Int      @id @default(autoincrement())
  url       String
  status    VideoStatus @default(PENDING)
  sessionId Int
  session   Session  @relation(fields: [sessionId], references: [id])
  metrics   Metric[]
}

enum VideoStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Metric {
  id        Int      @id @default(autoincrement())
  type      String   // e.g., "Speed", "Agility", "PoseAccuracy"
  value     Float
  playerId  Int
  player    Player   @relation(fields: [playerId], references: [id])
  videoId   Int?
  video     Video?   @relation(fields: [videoId], references: [id])
  createdAt DateTime @default(now())
}

enum SessionType {
  TECHNICAL
  TACTICAL
  FITNESS
  RECOVERY
}

enum SessionStatus {
  PLANNED
  ONGOING
  COMPLETED
  CANCELLED
}

enum AttendanceStatus {
  PENDING
  PRESENT
  ABSENT
  EXCUSED
}
