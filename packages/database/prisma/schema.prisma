// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  slug         String?   @unique
  description  String?
  logoUrl      String?
  address      String?
  contactEmail String?
  contactPhone String?
  joinCode     String?  @unique // Secure code needed for COACH/PLAYER to join
  users        User[]
  teams        Team[]
  sessions     Session[]
  videos       Video[]
  videoClips   VideoClip[]
  tacticalBoards TacticalBoard[]
  matchAnalyses  MatchAnalysis[]
  playerAnalyses PlayerAnalysis[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model User {
  id                   Int            @id @default(autoincrement())
  email                String         @unique
  username             String         @unique
  password             String
  firstName            String?
  lastName             String?
  role                 Role           @default(COACH)
  organizationId       Int
  organization         Organization   @relation(fields: [organizationId], references: [id])
  failedLoginAttempts  Int            @default(0)
  lockoutUntil         DateTime?
  resetPasswordToken   String?        @unique
  resetPasswordExpires DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  coachProfile         Coach?
  playerProfile        Player?
  refreshTokens        RefreshToken[]
  sessionParticipants  SessionParticipant[]
  todos                Todo[]
  tacticalBoards       TacticalBoard[]
}

model RefreshToken {
  id          Int      @id @default(autoincrement())
  hashedToken String   @unique
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
}

enum Role {
  SUPER_ADMIN
  CLUB_ADMIN
  COACH
  ANALYST
  PLAYER
}

model Coach {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  user         User     @relation(fields: [userId], references: [id])
  bio          String?
  specialty    String[] // e.g., ["Tactical", "Goalkeeping"]
  licenseLevel String[] // e.g., ["UEFA Pro", "AFC A"]
  teams        Team[]
  sessions     Session[]
  sessionParticipants SessionParticipant[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Player {
  id      Int      @id @default(autoincrement())
  userId  Int      @unique
  user    User     @relation(fields: [userId], references: [id])
  teamId  Int?
  team    Team?    @relation(fields: [teamId], references: [id])
  metrics Metric[]
  sessionParticipants SessionParticipant[]
  phone        String?
  address      String?
  city         String?
  country      String?
  postalCode   String?
  birthdate    DateTime?
  nationality  String?

  // Bio / physical
  position           Position?
  secondaryPositions String[]
  heightCm           Int?
  weightKg           Int?
  dominantFoot       DominantFoot?
  bio                String?
  attributes         Json?

  // Metadata
  isActive          Boolean           @default(true)
  profileVisibility ProfileVisibility?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  scorers           Scorer[]
  videoClips        VideoClip[]
  formationPositions FormationPosition[]
  playerAnalyses     PlayerAnalysis[]
}

enum Position {
  GK
  CB
  LB
  RB
  LWB
  RWB
  DM
  CM
  AM
  LM
  RM
  LW
  RW
  ST
  CF
}

model Team {
  id             Int          @id @default(autoincrement())
  name           String
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])
  coachId        Int
  coach          Coach        @relation(fields: [coachId], references: [id])
  players        Player[]
  sessions       Session[]
  matches        Match[]
  formations     Formation[]
  tacticalBoards TacticalBoard[]
}

enum DominantFoot {
  LEFT
  RIGHT
  BOTH
}

enum ProfileVisibility {
  PUBLIC
  INTERNAL
  PRIVATE
}

model Session {
  id             Int          @id @default(autoincrement())
  title          String
  date           DateTime
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])
  coachId        Int
  coach          Coach        @relation(fields: [coachId], references: [id])
  videos         Video[]
  teamId         Int?
  team           Team?        @relation(fields: [teamId], references: [id])

  type           SessionType  @default(TECHNICAL)
  duration       Int?         // duration in minutes
  intensity      Int?         // 1-10 scale
  status         SessionStatus @default(PLANNED)
  venue          String?
  notes          String?

  participants   SessionParticipant[]
  playerAnalyses PlayerAnalysis[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  todos          Todo[]
}

model SessionParticipant {
  id              Int             @id @default(autoincrement())
  sessionId       Int
  session         Session         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  playerId        Int?
  player          Player?         @relation(fields: [playerId], references: [id])
  coachId         Int?
  coach           Coach?          @relation(fields: [coachId], references: [id])
  userId          Int?
  user            User?           @relation(fields: [userId], references: [id])
  role            String?
  attendanceStatus AttendanceStatus @default(PENDING)
  joinedAt        DateTime?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([sessionId, playerId])
  @@unique([sessionId, coachId])
  @@unique([sessionId, userId])
}

model Video {
  id            Int           @id @default(autoincrement())
  storagePath   String
  originalName  String?
  type          VideoType      @default(OTHER)
  status        VideoStatus    @default(PENDING)

  durationSec   Int?
  fps           Int?
  width         Int?
  height        Int?

  organizationId Int
  organization   Organization   @relation(fields: [organizationId], references: [id])

  sessionId     Int?
  session       Session?       @relation(fields: [sessionId], references: [id])

  matchId       Int?
  match         Match?         @relation(fields: [matchId], references: [id])

  clips         VideoClip[]
  analysisJobs  AnalysisJob[]
  metrics       Metric[]
  matchAnalyses MatchAnalysis[]
  playerAnalyses PlayerAnalysis[]
  createdAt     DateTime       @default(now())
}

model VideoClip {
  id          Int        @id @default(autoincrement())
  videoId     Int
  video       Video      @relation(fields: [videoId], references: [id], onDelete: Cascade)

  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])

  playerId    Int?
  player      Player?    @relation(fields: [playerId], references: [id])

  startSec    Int
  endSec      Int

  label       String?
  tags        String[]

  createdBy   ClipSource @default(MANUAL)
  metadata    Json?

  createdAt   DateTime   @default(now())
}

model AnalysisJob {
  id           Int            @id @default(autoincrement())
  videoId      Int
  video        Video          @relation(fields: [videoId], references: [id], onDelete: Cascade)

  modelVersion String
  status       AnalysisStatus  @default(QUEUED)

  results      AnalysisResult[]

  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime        @default(now())
}

model AnalysisResult {
  id            Int            @id @default(autoincrement())
  analysisJobId Int
  analysisJob   AnalysisJob    @relation(fields: [analysisJobId], references: [id], onDelete: Cascade)

  type          AnalysisType
  payload       Json
}

model Match {
  id          Int              @id @default(autoincrement())
  teamId      Int
  team        Team             @relation(fields: [teamId], references: [id])

  opponent    String
  competition CompetitionType?
  venue       String?
  matchDate   DateTime

  result      MatchResult?

  videos      Video[]
  todos       Todo[]
  tacticalBoards TacticalBoard[]
  matchAnalyses MatchAnalysis[]
  createdAt   DateTime @default(now())
}

model MatchResult {
  id           Int      @id @default(autoincrement())
  matchId      Int      @unique
  match        Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  
  homeScore    Int      @default(0)
  awayScore    Int      @default(0)
  details      String?  
  
  scorers      Scorer[]
  
  homePenalties Int?
  awayPenalties Int?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Scorer {
  id            Int         @id @default(autoincrement())
  matchResultId Int
  matchResult   MatchResult @relation(fields: [matchResultId], references: [id], onDelete: Cascade)
  
  playerId      Int?        
  player        Player?     @relation(fields: [playerId], references: [id])
  
  playerName    String?     
  minute        String?     
  isHomeTeam    Boolean     @default(true)
  goalCount     Int         @default(1)
}

enum CompetitionType {
  LEAGUE
  CUP
  FRIENDLY
  OTHER
}

enum VideoStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum VideoType {
  TRAINING
  MATCH
  OTHER
}

enum ClipSource {
  MANUAL
  AI
}

enum AnalysisStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum AnalysisType {
  TRACKING
  HEATMAP
  EVENTS
  METRICS
}

model Metric {
  id        Int      @id @default(autoincrement())
  type      String   // e.g., "Speed", "Agility", "PoseAccuracy"
  value     Float
  playerId  Int
  player    Player   @relation(fields: [playerId], references: [id])
  videoId   Int?
  video     Video?   @relation(fields: [videoId], references: [id])
  createdAt DateTime @default(now())
}

enum SessionType {
  TECHNICAL
  TACTICAL
  FITNESS
  RECOVERY
}

enum SessionStatus {
  PLANNED
  ONGOING
  COMPLETED
  CANCELLED
}

enum AttendanceStatus {
  PENDING
  PRESENT
  ABSENT
  EXCUSED
}

model Formation {
  id        Int                 @id @default(autoincrement())
  name      String
  template  String
  teamId    Int
  team      Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  isActive       Boolean             @default(false)
  positions      FormationPosition[]
  tacticalBoards TacticalBoard[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model FormationPosition {
  id          Int       @id @default(autoincrement())
  formationId Int
  formation   Formation @relation(fields: [formationId], references: [id], onDelete: Cascade)
  role        String
  x           Float
  y           Float
  playerId    Int?
  player      Player?   @relation(fields: [playerId], references: [id])
}

model Todo {
  id        Int      @id @default(autoincrement())
  text      String
  done      Boolean  @default(false)
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchId   Int?
  match     Match?   @relation(fields: [matchId], references: [id], onDelete: SetNull)
  sessionId Int?
  session   Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TacticalBoard {
  id              Int           @id @default(autoincrement())
  name            String
  teamId          Int
  team            Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  formationId     Int?
  formation       Formation?    @relation(fields: [formationId], references: [id], onDelete: SetNull)
  
  formationData    Json?        // Full state of player positions { [playerId]: {x, y} }
  annotations      Json         @default("[]")
  instructions     Json         @default("[]")
  
  organizationId   Int
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  createdBy        Int?
  user             User?        @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  
  matches          Match[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model MatchAnalysis {
  id              Int           @id @default(autoincrement())
  title           String
  date            DateTime
  matchId         Int?          
  match           Match?        @relation(fields: [matchId], references: [id])
  homeTeam        String
  awayTeam        String
  notes           String?
  inputMode       String        @default("manual") // "manual" | "video"
  videoId         Int?
  video           Video?        @relation(fields: [videoId], references: [id])
  matchStats      Json
  matchEvents     Json
  organizationId  Int
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model PlayerAnalysis {
  id              Int           @id @default(autoincrement())
  title           String
  date            DateTime
  playerId        Int
  player          Player        @relation(fields: [playerId], references: [id])
  sessionId       Int?
  session         Session?      @relation(fields: [sessionId], references: [id])
  notes           String?
  inputMode       String        @default("manual") // "manual" | "video"
  status          AnalysisStatus @default(COMPLETED)
  videoId         Int?
  video           Video?        @relation(fields: [videoId], references: [id])
  analysisData    Json
  organizationId  Int
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}
