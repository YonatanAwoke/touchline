{
  "name": "touchline",
  "private": true,
  "scripts": {
    "dev:frontend": "bun --cwd apps/frontend dev",
    "dev:backend": "bun --cwd apps/backend dev --port 3001",
    "build:all": "bun run build --filter '*'",
    "db:generate": "bun --cwd packages/database prisma generate",
    "db:push": "bun --cwd packages/database prisma db push",
    "postinstall": "prisma generate --schema packages/database/prisma/schema.prisma"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "devDependencies": {
    "@types/bun": "^1.3.6",
    "prisma": "^7.8.0"
  },
  "dependencies": {}
}